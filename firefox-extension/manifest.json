{
  "manifest_version": 2,
  "name": "Earmark — Save to your reader",
  "version": "1.0.7",
  "description": "Save the current page — exactly as rendered in your browser — to your self-hosted Earmark server for reading in the Android app.",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": "icons/icon.svg",
    "default_title": "Save to Earmark"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "save-page": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Save the current page to Earmark"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "readlater@selfhosted.local",
      "strict_min_version": "102.0",
      "update_url": "https://readlater-mbent.fly.dev/extension/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
